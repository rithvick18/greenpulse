# GreenPulse Django backend environment configuration.
# Copy this file to `.env` and adjust the values as needed. Settings.py reads
# these via os.getenv; sqlite + Redis-on-localhost are used by default when the
# Postgres/Redis variables are absent.

# Django secret key (falls back to an insecure dev default if unset).
SECRET_KEY=django-insecure-change-me-in-production

# PostgreSQL / TimescaleDB (optional — sqlite is used when POSTGRES_DB/POSTGRES_HOST are unset).
POSTGRES_DB=greenpulse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (used to cache the latest telemetry snapshot; optional).
REDIS_URL=redis://localhost:6379/0
