# GreenPulse frontend environment configuration.
#
# By default the frontend calls the backend via relative "/api/..." URLs, which
# the Vite dev server proxies to Django (see vite.config.ts). No variable needs
# to be set for local development.

# Optional: override the API base URL for production deployments where the
# backend is served from a different origin. Leave unset to use relative paths.
# VITE_API_BASE_URL=https://api.example.com
