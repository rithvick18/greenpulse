# Application Environment
DEBUG=True
ENVIRONMENT=development
APP_NAME=GreenPulse OS Backend
API_V1_STR=/api/v1

# Security / JWT
SECRET_KEY=change_this_super_secret_jwt_key_for_production_environment_32bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/greenpulse

# Redis (Pub/Sub & Cache)
REDIS_URL=redis://localhost:6379/0

# MQTT Broker (Optional - set SIMULATION_ENABLED=True if broker not available)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_SUB=sensors/+/telemetry

# Simulation Mode (Generates fake sensor telemetry automatically)
SIMULATION_ENABLED=True

# Celery Background Tasks (Optional - if empty or unset, falls back to asyncio tasks)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
WS_CONNECTION_LIMIT_PER_MINUTE=10
