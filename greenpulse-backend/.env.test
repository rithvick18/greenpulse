# Application Environment
DEBUG=True
ENVIRONMENT=testing
APP_NAME=GreenPulse OS Backend (Test)
API_V1_STR=/api/v1

# Security / JWT
SECRET_KEY=test_secret_key_for_unit_and_integration_testing_greenpulse_32b
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite in-memory for testing)
DATABASE_URL=sqlite+aiosqlite:///:memory:

# Redis (Test)
REDIS_URL=redis://localhost:6379/15

# MQTT Broker (Disabled during tests)
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=1883
MQTT_TOPIC_SUB=sensors/+/telemetry

# Simulation Mode (Disabled in tests to avoid background loop noise)
SIMULATION_ENABLED=False

# Celery (Disabled in tests)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=1000
WS_CONNECTION_LIMIT_PER_MINUTE=1000
